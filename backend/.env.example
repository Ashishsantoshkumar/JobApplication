# Server configurations
PORT=5000

# Database configurations (Docker PostgreSQL with pgvector)
# Set this to use a live PostgreSQL instance. If left blank or connection fails, 
# the backend will fall back to an in-memory/JSON DB simulation with cosine similarity.
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_matching

# OpenAI configuration (required for active AI parsing and vector embedding generation)
# If not provided, the system will use a mockup resume parser and local embedding generator.
OPENAI_API_KEY=your_openai_api_key_here
